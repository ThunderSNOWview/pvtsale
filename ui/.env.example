# Required: WalletConnect / Reown project id — https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: Pinata (IPFS uploads, if you use them)
# VITE_PINATA_JWT=
# VITE_GATEWAY_URL=

# Optional: custom API root (defaults in src/configs/constants.ts if unset)
# VITE_BACKEND_API_ROOT=

# Optional: override PrivacyPresaleFactory on Sepolia (see src/web3/core/constants/addresses.ts)
# VITE_PRESALE_FACTORY_CA=
